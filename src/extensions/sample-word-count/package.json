{
  "name": "word-count-pro",
  "displayName": "Word Count Pro",
  "description": "Real-time word count with reading time estimation and writing goals.",
  "version": "1.0.0",
  "publisher": "cognition",
  "engines": { "cognitionWp": "^1.0.0" },
  "categories": ["Productivity", "Writing"],
  "keywords": ["word count", "reading time", "goals", "statistics"],
  "main": "index.js",
  "icon": "icon.png",
  "activationEvents": ["onStartup"],
  "contributes": {
    "commands": [
      {
        "command": "wordcount.show",
        "title": "Show Word Count Details",
        "category": "Word Count Pro",
        "icon": "",
        "enablement": "true"
      },
      {
        "command": "wordcount.setGoal",
        "title": "Set Writing Goal",
        "category": "Word Count Pro",
        "icon": "",
        "enablement": "true"
      }
    ],
    "menus": [],
    "keybindings": [
      {
        "command": "wordcount.show",
        "key": "ctrl+shift+w",
        "mac": "cmd+shift+w",
        "when": "editorFocus"
      }
    ],
    "configuration": {
      "title": "Word Count Pro",
      "properties": {
        "wordcount.goal": {
          "type": "number",
          "default": 500,
          "description": "Daily writing goal (in words)",
          "enum": null
        },
        "wordcount.showReadingTime": {
          "type": "boolean",
          "default": true,
          "description": "Show estimated reading time",
          "enum": null
        }
      }
    },
    "themes": [],
    "views": [],
    "statusBarItems": [],
    "sidebarItems": [],
    "documentFormatters": [],
    "exportFormats": [],
    "importFormats": []
  },
  "dependencies": {},
  "devDependencies": {}
}
